# Amazon MCP — environment template (copy to .env)
# All credential fields use PLACEHOLDER_* — replace only for live SP-API mode.

# ── LWA (Login with Amazon) — required for live SP-API ─────────────────────
AMAZON_LWA_CLIENT_ID=PLACEHOLDER_LWA_CLIENT_ID
AMAZON_LWA_CLIENT_SECRET=PLACEHOLDER_LWA_CLIENT_SECRET
AMAZON_LWA_REFRESH_TOKEN=PLACEHOLDER_LWA_REFRESH_TOKEN

# ── SP-API ───────────────────────────────────────────────────────────────────
AMAZON_SP_API_REGION=na
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_SELLER_ID=PLACEHOLDER_SELLER_ID

# ── Advertising API (optional; falls back to LWA creds) ────────────────────
AMAZON_ADS_CLIENT_ID=PLACEHOLDER_ADS_CLIENT_ID
AMAZON_ADS_CLIENT_SECRET=PLACEHOLDER_ADS_CLIENT_SECRET
AMAZON_ADS_REFRESH_TOKEN=PLACEHOLDER_ADS_REFRESH_TOKEN
AMAZON_ADS_PROFILE_ID=PLACEHOLDER_ADS_PROFILE_ID

# ── Runtime ──────────────────────────────────────────────────────────────────
AMAZON_MCP_DRY_RUN=1
AMAZON_CACHE_TTL=300
# AMAZON_MCP_DATA_DIR=/var/lib/amazon-mcp/data
# AMAZON_MCP_TRANSPORT=stdio
# AMAZON_MCP_HOST=127.0.0.1
# AMAZON_MCP_PORT=8780
# AMAZON_MCP_API_KEY=PLACEHOLDER_GENERATE_A_STRONG_SECRET
# AMAZON_MCP_IP_ALLOWLIST=127.0.0.1

# ── Notifications (pro / optional) ───────────────────────────────────────────
NOTIFY_EMAIL_ENABLED=0
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_TLS=1
NOTIFY_SMTP_USERNAME=
NOTIFY_SMTP_PASSWORD=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
NOTIFY_SES_REGION=
NOTIFY_SES_FROM=
NOTIFY_SLACK_ENABLED=0
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_SLACK_CHANNEL=#amazon-alerts
NOTIFY_DISCORD_ENABLED=0
NOTIFY_DISCORD_WEBHOOK_URL=
NOTIFY_WEBHOOK_ENABLED=0
NOTIFY_WEBHOOK_URL=
NOTIFY_WEBHOOK_SECRET=
NOTIFY_WEBHOOK_HEADERS=
